# Mobile Terminal startup config
# Copy this file to mobile-terminal.env and customize as needed.

MOBILE_TERMINAL_TAILSCALE=true
MOBILE_TERMINAL_NO_TOKEN=true
MOBILE_TERMINAL_PORT=8085
MOBILE_TERMINAL_SESSION=mobile-terminal
# Optional overrides. If omitted, the server defaults to your home directory and
# current login shell.
# MOBILE_TERMINAL_CWD=/Users/you
# MOBILE_TERMINAL_SHELL=/bin/zsh
# MOBILE_TERMINAL_HOST=0.0.0.0
# Optional: restrict access to one Tailscale IP
# MOBILE_TERMINAL_ALLOW_CLIENTS=100.101.102.103
